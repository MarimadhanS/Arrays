import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
        Scanner sc=new Scanner(System.in);
        int size=sc.nextInt();
        int arr[]=new int[size];
        for(int i=0;i<size;i++) arr[i]=sc.nextInt();
        for(int i=0,j=size-1;i<j;i++,j--)
        {
            if(arr[i]==arr[j])
            {
                System.out.print("Yes");
                return;
            }
        }
        System.out.print("No");
    }
}
